# ═══════════════════════════════════════════════════════════════════════════════
# 🎬 CONFIGURAÇÕES DO MONITOR DE CINEMA - ODISSEIA
# ═══════════════════════════════════════════════════════════════════════════════
# MODO: STANDALONE (Independente do Monitor Harry)
# NOTA: Este script funciona 100% localmente. Harry é OPCIONAL.

# 📍 URL da sessão de cinema a monitorar
# Formato: https://checkout.ingresso.com/assentos?sessionId=XXXXX&partnership=home
CINEMA_URL=https://checkout.ingresso.com/assentos?sessionId=85452676&partnership=home

# ⏱️ Intervalo entre verificações (em milissegundos)
# Padrão: 60000 (1 minuto)
# Para teste rápido: 30000 (30 segundos)
CHECK_INTERVAL_MS=60000

# 🪑 Quantidade de assentos CONSECUTIVOS a procurar
# Padrão: 2 (casal)
# Use 2 para casal, 3 ou 4 para grupos maiores
CONSECUTIVE_SEATS=2

# ═══════════════════════════════════════════════════════════════════════════════
# 💾 ARMAZENAMENTO LOCAL (Sempre Ativado)
# ═══════════════════════════════════════════════════════════════════════════════
# Os alertas SÃO SEMPRE salvos localmente em alertas/alertas-YYYY-MM-DD.json
# Nenhuma configuração necessária - funciona automaticamente

# Salvar histórico de varreduras (mais detalhado, opcional)
SAVE_SCAN_HISTORY=false

# ═══════════════════════════════════════════════════════════════════════════════
# 🔌 NOTIFICAÇÃO PARA MONITOR HARRY (OPCIONAL - Desacoplado)
# ═══════════════════════════════════════════════════════════════════════════════
# NÃO é necessário para funcionar!
# O script funciona 100% independentemente.
# Só configure se quiser enviar alertas para o Harry também.

# ❌ Desabilitado por padrão (false)
# ✅ Mude para true APENAS se quiser notificar Harry
NOTIFICAR_HARRY=false

# Protocolo de comunicação
HARRY_PROTOCOL=http:

# Host/IP onde está rodando o Monitor Harry
# Padrão: localhost (para testes locais com mock-harry-server.js)
HARRY_HOST=localhost

# Porta do serviço do Monitor Harry
# Padrão: 3000
HARRY_PORT=3000

# Caminho do endpoint para enviar alertas
HARRY_ENDPOINT=/api/alerts/cinema

# Token de autenticação (se necessário)
# Descomente se o Harry exigir autenticação
# HARRY_AUTH_TOKEN=seu_token_aqui

# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 CONFIGURAÇÕES AVANÇADAS
# ═══════════════════════════════════════════════════════════════════════════════

# Ativar modo debug (mais logs verbosos)
DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 COMO USAR
# ═══════════════════════════════════════════════════════════════════════════════

# TESTE 1: Execução Simples (Recomendado)
#   npm run monitor:cinema
#   → Monitora e salva alertas localmente, sem depender de Harry

# TESTE 2: Com Debug
#   npm run monitor:cinema:debug
#   → Mesma coisa, mas com logs mais detalhados

# TESTE 3: Com Notificação do Harry Local (Opcional)
#   a) Terminal 1: node mock-harry-server.js
#   b) Mude: NOTIFICAR_HARRY=true
#   c) Terminal 2: npm run monitor:cinema
#   → Salva localmente E notifica o Mock Harry

# TESTE 4: Com Harry Real (Quando integrar)
#   Mude: NOTIFICAR_HARRY=true
#   Mude: HARRY_HOST=seu-servidor-real.com
#   Mude: HARRY_PORT=sua-porta-real
#   npm run monitor:cinema
#   → Salva localmente E notifica seu Harry real

